<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Vehicle Manager" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Vehicle Manager">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-800">
    <nav class="bg-blue-600 text-white p-4 shadow-md">
      <div class="container mx-auto flex justify-between items-center">
        <h1 class="text-xl font-bold">🚗 Veículo App</h1>

        <div class="flex items-center gap-6">
          <div class="space-x-4">
            <%= link_to "Veículos", vehicles_path, class: "hover:underline" %>
            <%= link_to "Carros", cars_path, class: "hover:underline" %>
            <%= link_to "Motos", motorcycles_path, class: "hover:underline" %>
          </div>

          <div class="flex items-center gap-4">
            <% if admin_signed_in? %>
              <p class="font-semibold">
                Admin: <%= current_admin.email %>
              </p>

              <%= link_to "Sair", destroy_admin_session_path,
                  data: { turbo_method: :delete },
                  class: "hover:underline" %>

            <% elsif user_signed_in? %>
              <%= link_to "Meus aluguéis", my_rentals_rentals_path, class: "hover:underline" %>
              
              <p class="font-semibold">
                <%= current_user.username %>
              </p>

              <%= link_to "Sair", destroy_user_session_path,
                  data: { turbo_method: :delete },
                  class: "hover:underline" %>

            <% else %>
              <%= link_to "Entrar Usuário", new_user_session_path, class: "hover:underline" %>
              <%= link_to "Registrar", new_user_registration_path, class: "hover:underline" %>
              <%= link_to "Entrar Admin", new_admin_session_path, class: "hover:underline" %>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="container mx-auto mt-8 px-4">
      <% if notice %>
        <div class="bg-green-100 text-green-700 p-3 rounded mb-4">
          <%= notice %>
        </div>
      <% end %>

      <% if alert %>
        <div class="bg-red-100 text-red-700 p-3 rounded mb-4">
          <%= alert %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>