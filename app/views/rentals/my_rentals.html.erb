<div class="max-w-5xl mx-auto py-8">
  <h1 class="text-3xl font-bold text-gray-800 mb-8">Meus aluguéis</h1>

  <div class="mb-10">
    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Aluguel vigente</h2>

    <% if @current_rental.present? %>
      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
        <h3 class="text-xl font-semibold text-gray-800 mb-3">
          <%= @current_rental.vehicle.brand %> - <%= @current_rental.vehicle.model %>
        </h3>

        <p class="text-gray-600">Ano: <%= @current_rental.vehicle.year %></p>
        <p class="text-gray-600">Cor: <%= @current_rental.vehicle.color %></p>
        <p class="text-gray-600 mt-2">
          Início: <%= @current_rental.start_date.strftime("%d/%m/%Y") %>
        </p>
        <p class="text-gray-600">
          Fim: <%= @current_rental.end_date.strftime("%d/%m/%Y") %>
        </p>
        <p class="text-gray-600">
          Status: <span class="text-green-600 font-medium">Ativo</span>
        </p>

        <p class="text-xl font-bold text-green-600 mt-4">
          Total: R$ <%= number_to_currency(@current_rental.total_price, unit: "", separator: ",", delimiter: ".") %>
        </p>

        <div class="mt-4">
          <%= link_to "Ver detalhes", rental_path(@current_rental),
              class: "bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition" %>
        </div>
      </div>
    <% else %>
      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200 text-gray-500">
        Você não possui aluguel vigente no momento.
      </div>
    <% end %>
  </div>

  <div>
    <h2 class="text-2xl font-semibold text-gray-700 mb-4">Histórico de aluguéis</h2>

    <% if @rental_history.any? %>
      <div class="space-y-4">
        <% @rental_history.each do |rental| %>
          <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-semibold text-gray-800">
                  <%= rental.vehicle.brand %> - <%= rental.vehicle.model %>
                </h3>
                <p class="text-gray-600">Ano: <%= rental.vehicle.year %></p>
                <p class="text-gray-600">Cor: <%= rental.vehicle.color %></p>
                <p class="text-gray-600 mt-2">
                  Período: <%= rental.start_date.strftime("%d/%m/%Y") %> até <%= rental.end_date.strftime("%d/%m/%Y") %>
                </p>
              </div>

              <span class="bg-gray-200 text-gray-700 px-3 py-1 rounded text-sm">
                Finalizado
              </span>
            </div>

            <p class="text-lg font-bold text-green-600 mt-4">
              Total: R$ <%= number_to_currency(rental.total_price, unit: "", separator: ",", delimiter: ".") %>
            </p>

            <div class="mt-4">
              <%= link_to "Ver detalhes", rental_path(rental),
                  class: "bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 transition" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-200 text-gray-500">
        Você ainda não possui histórico de aluguéis finalizados.
      </div>
    <% end %>
  </div>
</div>