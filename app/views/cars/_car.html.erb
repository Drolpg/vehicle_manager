<div style="border: 1px solid #ccc; padding: 10px; margin-bottom: 10px;">
  <p>
    <strong>Marca:</strong>
    <%= car.brand %>
  </p>

  <p>
    <strong>Modelo:</strong>
    <%= car.model %>
  </p>

  <p>
    <strong>Ano:</strong>
    <%= car.year %>
  </p>

  <p>
    <strong>Valor:</strong>
    R$ <%= number_to_currency(car.price, unit: "", separator: ",", delimiter: ".") %>
  </p>

  <p>
    <strong>Cor:</strong>
    <%= car.color %>
  </p>
</div>