<div class="max-w-xl mx-auto bg-white p-8 rounded-xl shadow-md">

  <h2 class="text-2xl font-bold mb-6 text-gray-800">
    <%= car.new_record? ? "Novo Carro" : "Editar Carro" %>
  </h2>

  <%= form_with(model: car) do |form| %>

    <% if car.errors.any? %>
      <div class="bg-red-100 border border-red-300 text-red-700 p-4 rounded mb-6">
        <h3 class="font-semibold mb-2">
          <%= pluralize(car.errors.count, "erro") %> impediram o salvamento:
        </h3>
        <ul class="list-disc list-inside">
          <% car.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-4">
      <%= form.label :brand, "Marca", class: "block font-medium text-gray-700 mb-1" %>
      <%= form.text_field :brand,
          class: "w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400 focus:outline-none" %>
    </div>

    <div class="mb-4">
      <%= form.label :model, "Modelo", class: "block font-medium text-gray-700 mb-1" %>
      <%= form.text_field :model,
          class: "w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400 focus:outline-none" %>
    </div>

    <div class="mb-4">
      <%= form.label :year, "Ano", class: "block font-medium text-gray-700 mb-1" %>
      <%= form.number_field :year,
          class: "w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400 focus:outline-none" %>
    </div>

    <div class="mb-4">
      <%= form.label :price, "Preço", class: "block font-medium text-gray-700 mb-1" %>
      <%= form.number_field :price, step: 0.01,
          class: "w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400 focus:outline-none" %>
    </div>

    <div class="mb-6">
      <%= form.label :color, "Cor", class: "block font-medium text-gray-700 mb-1" %>
      <%= form.text_field :color,
          class: "w-full border rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-400 focus:outline-none" %>
    </div>

    <div class="flex justify-between items-center">
      <%= link_to "Voltar", cars_path,
          class: "text-gray-600 hover:underline" %>

      <%= form.submit car.new_record? ? "Criar Carro" : "Atualizar Carro",
          class: "bg-green-500 text-white px-6 py-2 rounded-lg hover:bg-green-600 transition" %>
    </div>

  <% end %>
</div>