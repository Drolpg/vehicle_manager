<h1 class="text-3xl font-bold mb-6">🚗 Veículos</h1>

<div class="mb-6 space-x-4">
  <%= link_to "Carros", cars_path,
      class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>

  <%= link_to "Motocicletas", motorcycles_path,
      class: "bg-purple-500 text-white px-4 py-2 rounded hover:bg-purple-600" %>
</div>

<div class="bg-white p-6 rounded-lg shadow-md mb-8">
  <h2 class="text-xl font-semibold mb-4">🔎 Filtros</h2>

  <%= search_form_for @q, html: { class: "grid grid-cols-1 md:grid-cols-3 gap-4" } do |f| %>

    <div>
      <%= f.label :brand_cont, "Marca contém", class: "block font-medium" %>
      <%= f.search_field :brand_cont,
          class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :model_cont, "Modelo contém", class: "block font-medium" %>
      <%= f.search_field :model_cont,
          class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :year_eq, "Ano exato", class: "block font-medium" %>
      <%= f.number_field :year_eq,
          class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :price_gteq, "Preço mínimo", class: "block font-medium" %>
      <%= f.number_field :price_gteq,
          class: "w-full border rounded px-3 py-2" %>
    </div>

    <div>
      <%= f.label :price_lteq, "Preço máximo", class: "block font-medium" %>
      <%= f.number_field :price_lteq,
          class: "w-full border rounded px-3 py-2" %>
    </div>

    <div class="flex items-end">
      <%= f.submit "Buscar",
          class: "bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 w-full" %>
    </div>

    <div class="md:col-span-2 mt-4 space-x-4">
      <%= sort_link(@q, :brand, "Ordenar por Marca",
          class: "text-blue-600 hover:underline") %>

      <%= sort_link(@q, :price, "Ordenar por Preço",
          class: "text-blue-600 hover:underline") %>
    </div>

  <% end %>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
  <% @vehicles.each do |vehicle| %>
    <div class="bg-white p-5 rounded-lg shadow hover:shadow-lg transition duration-300">
      
      <div class="flex justify-between items-center mb-3">
        <span class="text-sm bg-gray-200 px-2 py-1 rounded">
          <%= vehicle.type %>
        </span>
      </div>

      <h3 class="text-lg font-semibold">
        <%= vehicle.brand %> - <%= vehicle.model %>
      </h3>

      <p class="text-gray-600 mt-2">
        Ano: <%= vehicle.year %>
      </p>

      <p class="text-gray-600">
        Cor: <%= vehicle.color %>
      </p>

      <p class="text-xl font-bold mt-3 text-green-600">
        R$ <%= number_to_currency(vehicle.price, unit: "", separator: ",", delimiter: ".") %>
      </p>

    </div>
  <% end %>
</div>

<div class="mt-8">
  <%= paginate @vehicles %>
</div>